<Page
    x:Class="CubeOS95.OperatingSystems.CubeOS95.CubeOS95"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CubeOS95.OperatingSystems.CubeOS95"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml"
    Background="Transparent"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid
            x:Name="ShutDownWindow"
            Background="Transparent"
            Canvas.ZIndex="1"
            Visibility="Collapsed">
            <win2d:CanvasControl CreateResources="BackgroundCanvas_CreateResources" Draw="BackgroundCanvas_Draw" />
            <Grid
                x:Name="ShutDownWindowItself"
                Width="338"
                Height="240">
                <Border
                    x:Name="ShutDownWindowBorderLeftAndTop"
                    BorderBrush="White"
                    BorderThickness="2,2,0,0" />
                <Grid
                    x:Name="ShutDownWindowGrid"
                    Margin="2,2,1,1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="#C0C0C0">
                    <Grid
                        x:Name="ShutDownWindowTitleBar"
                        Width="332"
                        Height="29"
                        Margin="0,1,2,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Background="#000080">
                        <TextBlock
                            Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="/OperatingSystems/CubeOS95/Resources/Fonts/progresspixel.ttf#progresspixel"
                            FontWeight="Black"
                            Text="Restart/Shutdown" />
                        <Button
                            x:Name="CloseShutDownWindow"
                            Width="25"
                            Height="21"
                            Margin="0,5,4,3"
                            HorizontalAlignment="Right"
                            Click="CloseShutDownWindow_Click"
                            IsTabStop="False"
                            UseSystemFocusVisuals="False">
                            <Button.Resources>
                                <ResourceDictionary>
                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonForeground" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                </ResourceDictionary>
                            </Button.Resources>
                            <FontIcon
                                Margin="-3,-3,-2,-2"
                                FontFamily="/OperatingSystems/CubeOS95/Resources/Fonts/marlett.ttf#Marlett"
                                FontSize="16"
                                Glyph="&#x0072;" />
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                                    <Border
                                                        x:Name="BorderRightAndBottom"
                                                        BorderBrush="#000000"
                                                        BorderThickness="0,0,2,2">
                                                        <Border
                                                            x:Name="BorderLeftAndTop"
                                                            BorderBrush="#ffffff"
                                                            BorderThickness="2,2,0,0">
                                                            <Border
                                                                x:Name="BorderRightAndBottom2"
                                                                BorderBrush="#808080"
                                                                BorderThickness="0,0,2,2">
                                                                <Border
                                                                    x:Name="BorderLeftAndTop2"
                                                                    BorderBrush="#dfdfdf"
                                                                    BorderThickness="2,2,0,0">
                                                                    <ContentPresenter />
                                                                </Border>
                                                            </Border>
                                                        </Border>
                                                    </Border>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal">
                                                                <Storyboard>
                                                                    <PointerUpThemeAnimation Storyboard.TargetName="RootGrid" />
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="PointerOver">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderLeftAndTop" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="#ffffff" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderRightAndBottom" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="#000000" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderLeftAndTop2" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="#dfdfdf" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderRightAndBottom2" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="#808080" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed">
                                                                <Storyboard>
                                                                    <PointerDownThemeAnimation Storyboard.TargetName="RootGrid" />
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                        <Image
                            Width="56"
                            Height="56"
                            Margin="0,0,0,33"
                            Source="/OperatingSystems/CubeOS95/Resources/Icons/starticon_6.png" />
                        <Button
                            x:Name="RestartButton"
                            Width="140"
                            Height="33"
                            Margin="0,0,0,26"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Click="RestartButton_Click"
                            IsTabStop="False"
                            UseSystemFocusVisuals="False">
                            <Button.Resources>
                                <ResourceDictionary>
                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonForeground" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                </ResourceDictionary>
                            </Button.Resources>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="/OperatingSystems/CubeOS95/Resources/Fonts/progresspixel.ttf#progresspixel"
                                FontSize="15"
                                Text="Restart" />
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                                    <Border
                                                        x:Name="BorderRightAndBottom"
                                                        BorderBrush="Black"
                                                        BorderThickness="0,0,2,2">
                                                        <Border
                                                            x:Name="BorderLeftAndTop"
                                                            BorderBrush="White"
                                                            BorderThickness="2,2,0,0">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </Border>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal">
                                                                <Storyboard>
                                                                    <PointerUpThemeAnimation Storyboard.TargetName="RootGrid" />
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="PointerOver">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderLeftAndTop" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="White" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderRightAndBottom" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Black" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderLeftAndTop" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Black" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderRightAndBottom" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="White" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            x:Name="ShutDownButton"
                            Width="140"
                            Height="33"
                            Margin="0,0,0,15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Click="ShutDownButton_Click"
                            IsTabStop="False"
                            UseSystemFocusVisuals="False">
                            <Button.Resources>
                                <ResourceDictionary>
                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonForeground" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                </ResourceDictionary>
                            </Button.Resources>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="/OperatingSystems/CubeOS95/Resources/Fonts/progresspixel.ttf#progresspixel"
                                FontSize="15"
                                Text="Shutdown" />
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                                    <Border
                                                        x:Name="BorderRightAndBottom"
                                                        BorderBrush="Black"
                                                        BorderThickness="0,0,2,2">
                                                        <Border
                                                            x:Name="BorderLeftAndTop"
                                                            BorderBrush="White"
                                                            BorderThickness="2,2,0,0">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </Border>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal">
                                                                <Storyboard>
                                                                    <PointerUpThemeAnimation Storyboard.TargetName="RootGrid" />
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="PointerOver">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderLeftAndTop" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="White" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderRightAndBottom" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Black" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderLeftAndTop" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Black" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderRightAndBottom" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="White" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
                <Border
                    x:Name="ShutDownWindowBorderRightAndBottom"
                    BorderBrush="Black"
                    BorderThickness="0,0,2,2" />
            </Grid>
        </Grid>
        <Grid
            x:Name="GameModesAndChallengesWindow"
            Background="Transparent"
            Canvas.ZIndex="1"
            Visibility="Collapsed">
            <win2d:CanvasControl CreateResources="BackgroundCanvas_CreateResources" Draw="BackgroundCanvas_Draw" />
            <Grid
                x:Name="GameModesWindowItself"
                Width="388"
                Height="360"
                Margin="0,0,0,6"
                VerticalAlignment="Bottom">
                <Border
                    x:Name="GameModesWindowBorderLeftAndTop"
                    BorderBrush="White"
                    BorderThickness="2,2,0,0" />
                <Grid
                    x:Name="GameModesWindowGrid"
                    Margin="2,2,1,1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="#C0C0C0">
                    <Grid
                        x:Name="GameModesWindowTitleBar"
                        Width="382"
                        Height="29"
                        Margin="0,1,2,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Background="#000080">
                        <StackPanel Orientation="Horizontal">
                            <Image
                                Width="24"
                                Height="24"
                                Margin="2,0,0,0"
                                VerticalAlignment="Center"
                                Source="/OperatingSystems/CubeOS95/Resources/Icons/ico_post.png" />
                            <TextBlock
                                Margin="3,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontFamily="/OperatingSystems/CubeOS95/Resources/Fonts/progresspixel.ttf#progresspixel"
                                FontWeight="Black"
                                Text="Game modes" />
                        </StackPanel>
                        <Button
                            x:Name="CloseGameModesAndChallengesWindow"
                            Width="25"
                            Height="21"
                            Margin="0,5,4,3"
                            HorizontalAlignment="Right"
                            Click="CloseGameModesAndChallengesWindow_Click"
                            IsTabStop="False"
                            UseSystemFocusVisuals="False">
                            <Button.Resources>
                                <ResourceDictionary>
                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonForeground" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C0C0C0" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Black" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                </ResourceDictionary>
                            </Button.Resources>
                            <FontIcon
                                Margin="-3,-3,-2,-2"
                                FontFamily="/OperatingSystems/CubeOS95/Resources/Fonts/marlett.ttf#Marlett"
                                FontSize="16"
                                Glyph="&#x0072;" />
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                                    <Border
                                                        x:Name="BorderRightAndBottom"
                                                        BorderBrush="#000000"
                                                        BorderThickness="0,0,2,2">
                                                        <Border
                                                            x:Name="BorderLeftAndTop"
                                                            BorderBrush="#ffffff"
                                                            BorderThickness="2,2,0,0">
                                                            <Border
                                                                x:Name="BorderRightAndBottom2"
                                                                BorderBrush="#808080"
                                                                BorderThickness="0,0,2,2">
                                                                <Border
                                                                    x:Name="BorderLeftAndTop2"
                                                                    BorderBrush="#dfdfdf"
                                                                    BorderThickness="2,2,0,0">
                                                                    <ContentPresenter />
                                                                </Border>
                                                            </Border>
                                                        </Border>
                                                    </Border>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal">
                                                                <Storyboard>
                                                                    <PointerUpThemeAnimation Storyboard.TargetName="RootGrid" />
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="PointerOver">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderLeftAndTop" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="#ffffff" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderRightAndBottom" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="#000000" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderLeftAndTop2" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="#dfdfdf" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderRightAndBottom2" Storyboard.TargetProperty="BorderBrush">
                                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="#808080" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed">
                                                                <Storyboard>
                                                                    <PointerDownThemeAnimation Storyboard.TargetName="RootGrid" />
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    <Grid
                        x:Name="DifficultyLevelsAndMiniGames"
                        Height="316"
                        Margin="4,0,7,7"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Background="White">
                        <Border
                            x:Name="DifficultyLevelsAndMiniGamesBorderRightAndBottom01"
                            Margin="1,1,0,0"
                            BorderBrush="#3E3E3E"
                            BorderThickness="1,1,0,0" />
                        <Border
                            x:Name="DifficultyLevelsAndMiniGamesBorderRightAndBottom02"
                            BorderBrush="Black"
                            BorderThickness="1,1,0,0" />
                        <Border
                            x:Name="DifficultyLevelsAndMiniGamesBorderRightAndBottom03"
                            Margin="1,1,0,0"
                            BorderBrush="#737373"
                            BorderThickness="1,1,0,0" />
                        <StackPanel
                            x:Name="DifficultyLevelRelaxPanel"
                            Margin="37,17,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                            <Button
                                x:Name="DifficutlyLevelRelax"
                                Padding="0"
                                Click="DifficutlyLevelRelax_Click"
                                CornerRadius="0"
                                IsTabStop="False"
                                UseSystemFocusVisuals="False">
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                    </ResourceDictionary>
                                </Button.Resources>
                                <Image
                                    Width="49"
                                    Height="49"
                                    HorizontalAlignment="Center"
                                    Source="/OperatingSystems/CubeOS95/Resources/Icons/ico32_gamemode_Relax.png" />
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                                        <ContentPresenter
                                                            x:Name="ContentPresenter"
                                                            Padding="{TemplateBinding Padding}"
                                                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                            AutomationProperties.AccessibilityView="Raw"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            Content="{TemplateBinding Content}"
                                                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                                            ContentTransitions="{TemplateBinding ContentTransitions}" />
                                                        <VisualStateManager.VisualStateGroups>
                                                            <VisualStateGroup x:Name="CommonStates">
                                                                <VisualState x:Name="Normal">
                                                                    <Storyboard>
                                                                        <PointerUpThemeAnimation Storyboard.TargetName="RootGrid" />
                                                                    </Storyboard>
                                                                </VisualState>
                                                                <VisualState x:Name="PointerOver">
                                                                    <Storyboard>
                                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ButtonBackgroundPointerOver}" />
                                                                        </ObjectAnimationUsingKeyFrames>
                                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="BorderBrush">
                                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ButtonBorderBrushPointerOver}" />
                                                                        </ObjectAnimationUsingKeyFrames>
                                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ButtonForegroundPointerOver}" />
                                                                        </ObjectAnimationUsingKeyFrames>
                                                                    </Storyboard>
                                                                </VisualState>
                                                                <VisualState x:Name="Pressed">
                                                                    <Storyboard>
                                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ButtonBackgroundPressed}" />
                                                                        </ObjectAnimationUsingKeyFrames>
                                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="BorderBrush">
                                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ButtonBorderBrushPressed}" />
                                                                        </ObjectAnimationUsingKeyFrames>
                                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ButtonForegroundPressed}" />
                                                                        </ObjectAnimationUsingKeyFrames>
                                                                    </Storyboard>
                                                                </VisualState>
                                                            </VisualStateGroup>
                                                        </VisualStateManager.VisualStateGroups>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontFamily="/OperatingSystems/CubeOS95/Resources/Fonts/progresspixel.ttf#progresspixel"
                                FontSize="15"
                                Foreground="Black"
                                Text="Relax" />
                        </StackPanel>

                        <Border
                            x:Name="DifficultyLevelsAndMiniGamesBorderRightAndBottom1"
                            Margin="0,0,1,1"
                            BorderBrush="#AEAEAE"
                            BorderThickness="0,0,1,1" />
                        <Border
                            x:Name="DifficultyLevelsAndMiniGamesBorderRightAndBottom2"
                            BorderBrush="White"
                            BorderThickness="0,0,1,1" />
                        <Border
                            x:Name="DifficultyLevelsAndMiniGamesBorderRightAndBottom3"
                            Margin="0,0,1,1"
                            BorderBrush="#BCBCBC"
                            BorderThickness="0,0,1,1" />
                    </Grid>
                </Grid>
                <Border
                    x:Name="GameModesWindowBorderRightAndBottom"
                    BorderBrush="Black"
                    BorderThickness="0,0,2,2" />
